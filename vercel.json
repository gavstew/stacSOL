{
  "crons": [
    {
      "path": "/api/snapshot",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/referral-index",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/manager-fee-index",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/ingest-pool-events",
      "schedule": "*/5 * * * *"
