    { "source": "/liquidity", "destination": "/index.html" },
    { "source": "/liquidity/(.*)", "destination": "/index.html" },
    { "source": "/singlesided", "destination": "/index.html" },
    { "source": "/singlesided/(.*)", "destination": "/index.html" },
    { "source": "/portfolio", "destination": "/index.html" },
    { "source": "/portfolio/(.*)", "destination": "/index.html" },
    { "source": "/faq", "destination": "/index.html" },
    { "source": "/faq/(.*)", "destination": "/index.html" },
    { "source": "/leaderboard", "destination": "/index.html" },
    { "source": "/leaderboard/(.*)", "destination": "/index.html" },
    { "source": "/baitscope", "destination": "/index.html" },
    { "source": "/baitscope/(.*)", "destination": "/index.html" },
    { "source": "/liqmonsta", "destination": "/index.html" },
    { "source": "/liqmonsta/(.*)", "destination": "/index.html" }
  ]
}
