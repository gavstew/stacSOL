# --------------------------------------------------------------------------
# stacSOL local-dev env template. Copy to `.env.local` and fill in your own
# values. Never commit `.env` or `.env.local` — both are gitignored.
# --------------------------------------------------------------------------

# Solana RPC endpoint. Use any provider that supports getAccountInfo,
# getSignaturesForAddress, and (for the dapp's WebSocket subscriptions) a
# working WSS endpoint. Triton One, Helius, QuickNode, and Solana's free
# `https://api.mainnet-beta.solana.com` all work for read-only flows;
# rate-limit-aware paid plans are recommended for production.
RPC_URL="https://your-rpc-provider/your-key"

# Same value, exposed to the Vite client bundle. Keep them in sync. Anything
# you put here is publicly visible to every visitor of the deployed site —
# do NOT use a key with write/staking authority for this.
VITE_RPC_URL="https://your-rpc-provider/your-key"

# Postgres (Neon / Supabase / any managed PG). Used by /api/leaderboard,
# /api/history, /api/snapshot, /api/referral-index. Optional — those routes
# 500 cleanly without it; the rest of the app works fine.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Birdeye API key. Used by /api/snapshot and /api/lp for token-pair stats.
# Free-tier key works. Get one at https://birdeye.so/
BIRDEYE_API_KEY=""

# Jupiter API key. Used by /api/jup-quote and /api/jup-swap to fetch swap
# quotes for the LP zap-in flows. Free-tier key works. Get one at
# https://developers.jup.ag/portal
JUPITER_API_KEY=""
